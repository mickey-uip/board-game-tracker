rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── ユーザープロフィール ──
    // 読み取り: ログイン済みユーザーなら誰でも（フレンドコード検索のため）
    // 書き込み: 本人のみ
    match /users/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;

      // ── ローカルプレイヤー（サブコレクション）──
      // 読み書き: 本人のみ
      match /localPlayers/{playerId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // ── フレンドリクエスト ──
    match /friendRequests/{docId} {
      // 読み取り: 送信者 or 受信者
      allow read: if request.auth != null &&
        (resource.data.fromUid == request.auth.uid ||
         resource.data.toUid == request.auth.uid);

      // 作成: ログイン済みかつ fromUid が自分
      allow create: if request.auth != null &&
        request.resource.data.fromUid == request.auth.uid;

      // 更新: 受信者のみ（承認/拒否）
      allow update: if request.auth != null &&
        resource.data.toUid == request.auth.uid;

      // 削除: 送信者 or 受信者（アカウント削除・リクエスト取消）
      allow delete: if request.auth != null &&
        (resource.data.fromUid == request.auth.uid ||
         resource.data.toUid == request.auth.uid);
    }

    // ── フレンド関係 ──
    match /friends/{docId} {
      // 読み取り: 当事者のみ
      allow read: if request.auth != null &&
        request.auth.uid in resource.data.userIds;

      // 作成: ログイン済みかつ自分が userIds に含まれる
      allow create: if request.auth != null &&
        request.auth.uid in request.resource.data.userIds;

      // 削除: 当事者のみ（フレンド解除）
      allow delete: if request.auth != null &&
        request.auth.uid in resource.data.userIds;
    }

    // ── ゲーム招待 ──
    match /gameInvites/{docId} {
      // 読み取り: 送信者 or 受信者
      allow read: if request.auth != null &&
        (resource.data.fromUid == request.auth.uid ||
         resource.data.toUid == request.auth.uid);

      // 作成: ログイン済みかつ fromUid が自分
      allow create: if request.auth != null &&
        request.resource.data.fromUid == request.auth.uid;

      // 更新: 送信者 or 受信者（受信者は承諾/辞退、送信者は除外/中止通知）
      allow update: if request.auth != null &&
        (resource.data.fromUid == request.auth.uid ||
         resource.data.toUid == request.auth.uid);

      // 削除: 送信者 or 受信者
      allow delete: if request.auth != null &&
        (resource.data.fromUid == request.auth.uid ||
         resource.data.toUid == request.auth.uid);
    }

    // ── 対戦記録 ──
    match /records/{docId} {
      // 読み取り: 参加者のみ
      allow read: if request.auth != null &&
        request.auth.uid in resource.data.participantUids;

      // 作成: ログイン済みかつ createdByUid が自分
      allow create: if request.auth != null &&
        request.resource.data.createdByUid == request.auth.uid;

      // 削除: 作成者のみ
      allow delete: if request.auth != null &&
        resource.data.createdByUid == request.auth.uid;
    }
  }
}
